rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function prescriptionAlreadyValidated(data) {
      return data.status in ['validated_by_patient', 'active', 'completed'] ||
        (data.validation != null && (
          data.validation.validatedByPatient == true ||
          data.validation.validatedAt is string ||
          data.validation.patientStartDate is string
        ));
    }

    function isPatientSingleValidationUpdate() {
      return request.auth.uid == resource.data.patientId &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'validation', 'statusUpdatedAt']) &&
        resource.data.status in ['sent', 'received'] &&
        request.resource.data.status == 'active' &&
        !prescriptionAlreadyValidated(resource.data) &&
        request.resource.data.validation.validatedByPatient == true &&
        request.resource.data.validation.validatedAt is string &&
        request.resource.data.validation.patientStartDate is string;
    }

    // Règles pour les utilisateurs - lecture pour tous les utilisateurs authentifiés
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Règles pour les liens docteur-patient
    match /doctor_patient_links/{docId} {
      allow read: if isSignedIn() && 
        (request.auth.uid == resource.data.doctorId || 
         request.auth.uid == resource.data.patientId);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.doctorId;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.doctorId;
    }
    
    // Règles pour les rendez-vous
    match /appointments/{docId} {
      allow read: if isSignedIn() && 
        (request.auth.uid == resource.data.doctorId || 
         request.auth.uid == resource.data.patientId);
      allow create: if isSignedIn() &&
        (request.auth.uid == request.resource.data.doctorId ||
         request.auth.uid == request.resource.data.patientId);
      allow update, delete: if isSignedIn() &&
        (request.auth.uid == resource.data.doctorId ||
         request.auth.uid == resource.data.patientId);
    }
    
    // Règles pour les médicaments - utilise idPrescription
    match /medications/{docId} {
      allow read: if isSignedIn() && 
        (request.auth.uid == resource.data.createdBy || 
         request.auth.uid == resource.data.patientId);
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.createdBy;
      allow update, delete: if isSignedIn() &&
        request.auth.uid == resource.data.createdBy;
    }
    
    // Règles pour les médicaments utilisateur
    match /userMedications/{docId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }
    
    // Règles pour les symptômes - utilise userId
    match /symptoms/{docId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }
    
    // Règles pour les rappels
    match /reminders/{docId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }
    
    // Règles pour les messages - nom de collection corrigé
    match /messages/{docId} {
      allow read: if isSignedIn() && 
        (request.auth.uid == resource.data.senderId || 
         request.auth.uid == resource.data.receiverId);
      allow create: if isSignedIn() &&
        (request.auth.uid == request.resource.data.senderId ||
         request.auth.uid == request.resource.data.receiverId);
      allow update, delete: if isSignedIn() &&
        (request.auth.uid == resource.data.senderId ||
         request.auth.uid == resource.data.receiverId);
    }
    
    // Règles pour les messages de chat (au cas où)
    match /chat_messages/{docId} {
      allow read: if isSignedIn() && 
        (request.auth.uid == resource.data.senderId || 
         request.auth.uid == resource.data.receiverId);
      allow create: if isSignedIn() &&
        (request.auth.uid == request.resource.data.senderId ||
         request.auth.uid == request.resource.data.receiverId);
      allow update, delete: if isSignedIn() &&
        (request.auth.uid == resource.data.senderId ||
         request.auth.uid == resource.data.receiverId);
    }
    
    // Règles pour les prescriptions
    match /prescriptions/{docId} {
      allow read: if isSignedIn() && 
        (request.auth.uid == resource.data.createdBy || 
         request.auth.uid == resource.data.patientId);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.createdBy;
      allow update, delete: if isSignedIn() &&
        (request.auth.uid == resource.data.createdBy ||
         isPatientSingleValidationUpdate());
    }
    
    // Règles pour les notifications
    match /notifications/{docId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }
    
    // Règles pour les profils publics
    match /public_profiles/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Règles pour les activités
    match /activities/{docId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }
  }
}